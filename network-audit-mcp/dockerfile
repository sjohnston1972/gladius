FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    nmap \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    mcp \
    paramiko \
    chromadb \
    sentence-transformers \
    python-dotenv

COPY server.py .

CMD ["python", "server.py"]