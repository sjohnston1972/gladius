              "value": "{\"$device_id\":\"019b5a89-8d84-7e66-bcfa-571e8129a968\",\"distinct_id\":\"142bfc861c26fe52165e1a4e3330343ff403e0f14cd84e4a9482b092979b7483#cefb5e07-1381-4e11-9b7a-22441395ce6c\",\"$sesid\":[1771534090701,\"019c77a9-01cf-7956-8e51-2a7bf23c8f00\",1771534090701],\"$epp\":true,\"$initial_person_info\":{\"r\":\"$direct\",\"u\":\"https://n8n.clydeford.net/workflows/demo\"}}"
